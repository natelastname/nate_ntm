// Root configuration model for the nate_oha runtime.
{
  "runtime":
  {
    // Runtime mode: 'agent' or 'echo'.
    "mode": "agent",
    // Enable extra debug logging in runtime assembly.
    "debug": false,
  },
  "llm":
  {
    // Model name.
    "model": "openai/gpt-4o",
    // API key.
    "api_key": null,
  },
  "openhands":
  {
    // One of 'always-ask', 'always-approve', or 'llm-approve'.
    "confirmation_mode": "llm-approve",
    // Whether token streaming is enabled.
    "streaming": false,
    // Base directory for workspaces. When omitted, runtime assembly will fall
    // back to the OpenHands default get_work_dir() behavior.
    "workspace_root": null,
    // Optional overrides for the conversation condenser used to summarize
    // history. When null, NateOHA's default LLMSummarizingCondenser settings
    // are used.
    "condenser": null,
    // Optional explicit tool definitions for the underlying OpenHands agent.
    // When null, a NateOHA-owned default tool set is used.
    "tools": null,
    // Optional list of default tool identifiers to always include in addition
    // to any custom tools. When null, a NateOHA-owned default set is used.
    "include_default_tools": null,
    // Optional limit on the number of tools that may run in parallel. When
    // null, a NateOHA default (typically 1) is used.
    "tool_concurrency_limit": null,
  },
  "prompt":
  {
    // Raw text for the <SOUL> section describing the agent's identity, values,
    // and persistent behavioral guidance. When set, this value is used
    // verbatim inside the <SOUL> section of the system prompt. When null or
    // empty, the <SOUL> section is rendered as an empty string.
    "soul_content": null,
    // Optional persona or tone guidance rendered as a dedicated feature block
    // outside of <SOUL>.
    "personality_text": "You are a coding assistant.",
    // Filename of the Jinja2 system prompt template under
    // src/nate_oha/prompts/. When null, the canonical 'system_prompt.j2'
    // template is used.
    "system_prompt_template": "system_prompt.j2",
  },
  "features":
  {
    // Configuration for the Agent Mail feature.
    "agent_mail":
    {
      // Whether the Agent Mail feature is enabled.
      "enabled": false,
      // Path or logical name for the Agent Mail project.
      "project": null,
      // Agent identity used for the bound Agent Mail user.
      "agent_identity": null,
      // Token or reference used to obtain credentials.
      "credentials_ref": "AGENT_MAIL_TEST_TOKEN",
      // Upstream mcp_agent_mail base URL.
      "upstream_url": null,
    },
    "python_uv_project":
    {
      // Whether the python_uv_project feature is enabled.
      "enabled": true,
    },
    "allow_proc_management":
    {
      // Whether the allow_proc_management feature is enabled.
      "enabled": false,
    },
  },
  // Base OpenHands mcp_config mapping. Features such as Agent Mail merge their
  // MCP servers into this structure during runtime assembly.
  "mcp_config": null,
}
